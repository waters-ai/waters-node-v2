[package]
name = "waters-node"
version = "1.0.0"
edition = "2021"
description = "WATERS Node v1.0 — Next-gen agent runtime. Hybrid LLM, distributed inference, code review pipeline, DTN, SPIFFE, MIN, 8-layer comms, post-quantum security, fractal bootstrap, knowledge payloads."

[[bin]]
name = "waters-node"
path = "src/main.rs"

[features]
default = []
kafka-transport = ["dep:rdkafka"]
dtn-support = []

[dependencies]
anyhow = "1"
atty = "0.2"
chrono = { version = "0.4", features = ["serde"] }
clap = { version = "4", features = ["derive"] }
glob = "0.3"
lazy_static = "1"
llama_cpp_rs = "0.3"
rdkafka = { version = "0.37", features = ["tokio"], optional = true }
redis = { version = "0.25", features = ["tokio-comp"] }
regex = "1"
reqwest = { version = "0.12", features = ["json", "blocking"] }
serde = { version = "1", features = ["derive"] }
serde_json = "1"
signature = "2.2.0"
tokio = { version = "1", features = ["full"] }
tokio-util = { version = "0.7", features = [] }
toml = "0.8"
tracing = "0.1"
tracing-subscriber = { version = "0.3", features = ["env-filter"] }
uuid = { version = "1", features = ["v4", "serde"] }
bincode = "1"
postcard = "1"
blake3 = "1"
rand = "0.8"
rand_chacha = "0.3"
ed25519-dalek = "2.0"
ml-dsa = { version = "0.1.0", features = ["alloc"] }
tick_counter = "0.4"
hex = "0.4"
[dev-dependencies]
tempfile = "3"
tokio-test = "0.4"