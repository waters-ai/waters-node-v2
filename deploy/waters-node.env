# WATERS Node — Environment file for systemd
# Copy to /home/ubuntu/waters-node/.env and fill in your values

# Required: LLM API key
DEEPSEEK_API_KEY=sk-your-key-here

# Required: Redis connection
REDIS_URL=redis://127.0.0.1:6379

# Optional: Chat bridges
TELEGRAM_BOT_TOKEN=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WECHAT_APP_ID=
WECHAT_APP_SECRET=
DISCORD_TOKEN=
DISCORD_CHANNEL_ID=

# Optional: SMTP/IMAP for Email bridge
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
FROM_ADDR=
